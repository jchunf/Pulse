    "Returns the seconds you've spent in a given app today, read from Pulse's local data only.": {
      "comment": "F-44 GetAppUsageTodayIntent — description shown when configuring the intent.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Returns the seconds you've spent in a given app today, read from Pulse's local data only."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "返回今天你在某个 App 中停留的秒数，仅读取 Pulse 本地数据。"
          }
        }
      }
    },
    "The bundle identifier of the app (e.g. com.apple.dt.Xcode for Xcode).": {
      "comment": "F-44 GetAppUsageTodayIntent — parameter description (bundle identifier example).",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The bundle identifier of the app (e.g. com.apple.dt.Xcode for Xcode)."
