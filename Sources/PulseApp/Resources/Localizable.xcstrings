        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "App 的 bundle 标识（例如 Xcode 是 com.apple.dt.Xcode）。"
          }
        }
      }
    },
    "Total key presses Pulse recorded for you today.": {
      "comment": "F-44 GetTodayKeystrokesIntent — description shown when configuring the intent.",
      "localizations": {
        "en": {
          "stringUnit": {
