          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用切换数据还不够——继续使用你的 Mac，这张卡片会告诉你今天是「检查员模式」还是「深度工作者模式」。"
          }
        }
      }
    },
