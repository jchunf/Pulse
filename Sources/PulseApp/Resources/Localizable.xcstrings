    "Pulse exited unexpectedly last time": {
      "comment": "F-49b CrashBeaconBanner — headline shown when last session did not shut down cleanly.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulse exited unexpectedly last time"
          }
