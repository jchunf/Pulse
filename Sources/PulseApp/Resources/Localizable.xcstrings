    "Update checks are always manual. Pulse never reaches the network on its own.": {
      "comment": "Settings About section footer — reinforces the user-initiated-only update promise.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Update checks are always manual. Pulse never reaches the network on its own."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查更新永远是你手动点的。Pulse 不会自动联网。"
