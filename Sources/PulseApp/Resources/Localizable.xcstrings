    "Pulse isn't writing — check Settings.": {
      "comment": "Menu-bar status headline shown when the collector is silently failing — usually a revoked permission. Replaces the older internal 'Collector idle' phrasing.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulse isn't writing — check Settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulse 没有写入数据 — 请检查设置。"
          }
        }
      }
    },
    "Couldn't start the collector: %@": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't start the collector: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法启动采集器：%@"
          }
        }
      }
    },
    "Dashboard": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dashboard"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仪表盘"
          }
        }
      }
    },
    "Database not available.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Database not available."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据库不可用。"
          }
        }
      }
    },
    "Database size": {
      "comment": "Menu-bar CountersView — disk footprint of Pulse's local database. Renamed from 'DB size' to use words a non-developer reads naturally.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Database size"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据库大小"
          }
        }
      }
    },
    "Database writes": {
      "comment": "Menu-bar CountersView — total number of times Pulse has flushed its in-memory buffer to the on-disk database. Renamed from 'Total flushes' to drop the implementation term.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Database writes"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据库写入次数"
          }
        }
      }
    },
    "Pulse · Year so far": {
      "comment": "F-24 YearWrappedView — header title.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Pulse · Year so far" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "Pulse · 今年至今" } }
      }
    },
    "%1$@ · as of %2$@": {
      "comment": "F-24 YearWrappedView header subtitle. %1$@ year, %2$@ short date.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%1$@ · as of %2$@" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "%1$@ · 截至 %2$@" } }
      }
    },
    "Days with Pulse": {
      "comment": "F-24 YearWrappedView — days-active card label.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Days with Pulse" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "和 Pulse 一起的天数" } }
      }
    },
    "Days in a row with 4+ active hours": {
      "comment": "ContinuityCard subtitle — explains the qualification rule the streak counter is built on.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Days in a row with 4+ active hours" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "连续保持每天活跃 4 小时以上" } }
      }
    },
    "A full week-long streak — keep going.": {
      "comment": "ContinuityCard milestone tooltip — first tier (current streak ≥ 7 days).",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "A full week-long streak — keep going." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "已经连续一整周 —— 继续保持。" } }
      }
    },
    "Two weeks in a row — that's the new normal now.": {
      "comment": "ContinuityCard milestone tooltip — second tier (current streak ≥ 14 days).",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Two weeks in a row — that's the new normal now." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "连续两周 —— 这已经成了你的新常态。" } }
      }
    },
    "A whole month of qualifying days. Rare and earned.": {
      "comment": "ContinuityCard milestone tooltip — third tier (current streak ≥ 30 days).",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "A whole month of qualifying days. Rare and earned." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "整整一个月每天都达标 —— 难得，也是你应得的。" } }
      }
    },
    "Recording since %@.": {
      "comment": "F-24 YearWrappedView — days-active subtitle. %@ short date of first event in the year.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Recording since %@." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "从 %@ 开始记录。" } }
      }
    },
    "Keystrokes": {
      "comment": "F-24 YearWrappedView — keystrokes card label.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Keystrokes" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "总按键数" } }
      }
    },
    "Pulse hasn't logged any cursor moves yet today. Move the mouse around — the number fills in within a minute.": {
      "comment": "MileageHeroCard day-zero placeholder — replaces the '0 mm + tiny-fraction-of-a-fingernail' reading that made a fresh dashboard feel broken.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Pulse hasn't logged any cursor moves yet today. Move the mouse around — the number fills in within a minute." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "Pulse 今天还没记录到光标移动。移动一下鼠标，数字会在一分钟内出现。" } }
      }
    },
    "Keystrokes + clicks per day": {
      "comment": "WeekTrendChart subtitle — explains what the y-axis is plotting so the chart is self-documenting.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Keystrokes + clicks per day" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "每日按键 + 点击总和" } }
      }
    },
    "less": {
      "comment": "WeekHourlyHeatmap legend — left end of the colour-intensity scale strip ('less ▢▢▢▢▢ more').",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "less" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "较少" } }
      }
    },
    "more": {
      "comment": "WeekHourlyHeatmap legend — right end of the colour-intensity scale strip ('less ▢▢▢▢▢ more').",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "more" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "较多" } }
      }
    },
    "Roughly %@ words — about %@ a mid-length novel.": {
      "comment": "F-24 YearWrappedView — keystrokes narrative. %1$@ formatted word count, %2$@ multiplier like '0.3×' or '2×' or fallback phrase.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Roughly %@ words — about %@ a mid-length novel." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "约 %@ 个单词 —— 大概是 %@ 一本中等长度小说。" } }
      }
    },
    "Mouse distance": {
      "comment": "F-24 YearWrappedView — mouse-distance card label.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Mouse distance" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "鼠标里程" } }
      }
    },
    "Most-used apps": {
      "comment": "F-24 YearWrappedView — top-apps card label.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Most-used apps" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "最常用 App" } }
      }
    },
    "Longest focus session": {
      "comment": "F-24 YearWrappedView — longest-focus card label.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Longest focus session" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "最长专注片段" } }
      }
    },
    "%1$@ on %2$@": {
      "comment": "F-24 YearWrappedView — longest-focus subtitle. %1$@ app display name, %2$@ short date.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%1$@ on %2$@" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "%1$@ · %2$@" } }
      }
    },
    "Busiest day": {
      "comment": "F-24 YearWrappedView — busiest-day card label.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Busiest day" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "最忙的一天" } }
      }
    },
    "Busiest day: %1$@ — %2$@ keystrokes + clicks combined.": {
      "comment": "Weekly HTML report — one-line highlight inside the hero. %1$@ is a localized weekday + date, %2$@ is the formatted sum of keystrokes + clicks. Positional specifiers because zh-Hans reorders the clauses.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Busiest day: %1$@ — %2$@ keystrokes + clicks combined."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最忙的一天：%1$@ —— 按键 + 点击合计 %2$@ 次。"
          }
        }
      }
    },
    "%@ keystrokes + clicks combined.": {
      "comment": "F-24 YearWrappedView — busiest-day subtitle. %@ formatted total event count.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%@ keystrokes + clicks combined." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "按键 + 点击合计 %@ 次。" } }
      }
    },
    "Your rhythm": {
      "comment": "F-24 YearWrappedView — peak-hour / rhythm card label.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Your rhythm" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "你的节奏" } }
      }
    },
    "Your peak hour. You were active across %lld of 24 hours of the day.": {
      "comment": "F-24 YearWrappedView — peak-hour subtitle. %lld is the count of distinct hours-of-day with activity.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Your peak hour. You were active across %lld of 24 hours of the day." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "你的活跃高峰时段。你在 24 小时中的 %lld 个小时段都活跃过。" } }
      }
    },
    "Pulse needs a few more hours of recorded activity before it can pick out your peak. Check back at the end of a fuller day.": {
      "comment": "F-24 YearWrappedView rhythm card — empty-state placeholder shown when there's not enough rolled-up activity to identify a peak hour.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Pulse needs a few more hours of recorded activity before it can pick out your peak. Check back at the end of a fuller day." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "Pulse 还需要再多记录几个小时的活动才能找出你的高峰时段。等忙完一整天再回来看看吧。" } }
      }
    },
    "Save as image…": {
      "comment": "F-24 YearWrappedView — export button label.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Save as image…" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "保存为图片…" } }
      }
    },
    "Save year wrapped image": {
      "comment": "F-24 YearWrappedView — NSSavePanel title for the export PNG.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Save year wrapped image" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "保存年度回顾图片" } }
      }
    },
    "Couldn't compute wrapped: %@": {
      "comment": "F-24 YearWrappedView — query-error fallback. %@ is the underlying error description.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Couldn't compute wrapped: %@" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "无法计算年度回顾：%@" } }
      }
    },
    "Open year so far…": {
      "comment": "F-24 SettingsView — Recap section button label.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Open year so far…" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "查看今年至今…" } }
      }
    },
    "Recap": {
      "comment": "F-24 SettingsView — section header.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Recap" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "回顾" } }
      }
    },
    "Year-to-date totals — keystrokes, mouse distance, top apps, longest focus session — rendered as a single page you can save as an image.": {
      "comment": "F-24 SettingsView — Recap section footer.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Year-to-date totals — keystrokes, mouse distance, top apps, longest focus session — rendered as a single page you can save as an image." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "今年至今的总数 —— 按键、鼠标里程、最常用 App、最长专注片段 —— 显示在单页面上，可保存为图片。" } }
      }
    },
    "Year so far": {
      "comment": "F-24 — window title for the year-wrapped window (`Window(_:id:)`).",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Year so far" } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "今年至今" } }
      }
    },
    "Daily active hours": {
      "comment": "F-42 ActivityWeightCard — card title (replaces the older 'Activity weight' which was metaphorical). Subtitle below the title is what gives the concrete read.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Daily active hours"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每日活跃时长"
          }
        }
      }
    },
    "Each ribbon goes from the app you left to the app you opened next; thicker ribbons mean more frequent switches.": {
      "comment": "AppSankeyCard explainer caption — names the columns and the ribbon-thickness convention so first-time users can decode the diagram without a legend.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each ribbon goes from the app you left to the app you opened next; thicker ribbons mean more frequent switches."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每条曲线都从你切走的 App 流向你切去的 App；越粗的曲线代表切换越频繁。"
          }
        }
      }
    },
    "DND / Focus mode time": {
      "comment": "F-37 FocusModeCard — card title. Replaces 'Focus mode today' to disambiguate from the DeepFocusCard ('Deep focus today') in the same Focus pane: this card measures macOS Focus / DND mode duration, not application-switch-free streaks.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DND / Focus mode time"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "勿扰 / 专注模式时长"
          }
        }
      }
    },
    "Apps you used together today": {
      "comment": "F-14 AppCombinationsCard — card title. Replaces the older 'App combinations today' which led with the engineer-y noun 'combination'; the new phrasing reads as a question the user might ask themselves.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apps you used together today"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今天一起使用的 App"
          }
        }
      }
    },
    "Live counts read straight from Pulse's local data file. A warning appears if Pulse hasn't written anything in the past minute — usually a sign that a permission was revoked.": {
      "comment": "Settings Diagnostics section footer — explains what the diagnostics card surfaces and why a user might see a warning there.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Live counts read straight from Pulse's local data file. A warning appears if Pulse hasn't written anything in the past minute — usually a sign that a permission was revoked."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "直接从 Pulse 的本地数据文件实时统计。如果过去一分钟 Pulse 没有写入任何东西，这里会出现警告 —— 通常意味着某项权限被撤销了。"
          }
        }
      }
    },
    "Diagnostics": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Diagnostics"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "诊断"
          }
        }
      }
    },
    "Dismiss": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dismiss"
