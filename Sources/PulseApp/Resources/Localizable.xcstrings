    "Longest": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Longest"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最长"
          }
        }
      }
    },
    "Deep-worker mode — most of your sessions today run half an hour or more.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deep-worker mode — most of your sessions today run half an hour or more."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "深度工作者模式——今天大多数会话都在半小时以上。"
          }
        }
      }
    },
    "Steady flow — sessions are long enough to settle into real work.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Steady flow — sessions are long enough to settle into real work."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "稳定心流——会话长度足以沉入真正的工作。"
          }
        }
      }
    },
    "Step %lld of %lld": {
      "comment": "Onboarding progress caption shown below the segmented progress bar (e.g. 'Step 3 of 5').",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step %lld of %lld"
          }
        },
        "zh-Hans": {
