    "Grant the permissions below in System Settings, then relaunch Pulse. Until then the numbers on this page won't update.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant the permissions below in System Settings, then relaunch Pulse. Until then the numbers on this page won't update."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在「系统设置」中授予下列权限，然后重启 Pulse。在那之前本页面的数字不会更新。"
          }
        }
      }
    },
    "Heatmap window": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Heatmap window"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "热力图窗口"
          }
        }
      }
    },
    "How many past days the weekly heatmap covers. Longer windows make each cell smaller; shorter windows emphasise recent pattern.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How many past days the weekly heatmap covers. Longer windows make each cell smaller; shorter windows emphasise recent pattern."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "热力图覆盖过去多少天。窗口越长，每个格子越小；越短越能突出近期模式。"
          }
        }
      }
    },
    "How often the Dashboard window re-queries the local database. Reducing the interval uses a tiny bit more CPU; raising it is fine for passive monitoring.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How often the Dashboard window re-queries the local database. Reducing the interval uses a tiny bit more CPU; raising it is fine for passive monitoring."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仪表盘窗口查询本地数据库的频率。间隔越短越耗 CPU；被动监控场景调大也无妨。"
          }
        }
      }
    },
